# Copy to .env.local and fill in before running locally.
# Generate secrets: openssl rand -hex 32
# Generate escrow keys: npm run generate:escrow-keys

# ── Supabase (local: supabase start && supabase status -o env) ──
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App URL (production: https://your-domain.com) ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Claude API — conversational intake + will assembly ──
ANTHROPIC_API_KEY=

# ── Razorpay (Test keys for development) ──
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Resend — nominee + billing emails (optional locally) ──
RESEND_API_KEY=

# ── Banyan escrow keypair — Shamir Share 3 encryption ──
# Run: npm run generate:escrow-keys
BANYAN_ESCROW_PUBKEY=
BANYAN_ESCROW_PRIVKEY=
NEXT_PUBLIC_BANYAN_ESCROW_PUBKEY=

# ── Token signing (required, min 32 chars each) ──
# openssl rand -hex 32
NOMINEE_TOKEN_SECRET=
VETO_TOKEN_SECRET=

# ── Supabase Edge Function webhook (release-event-notify) ──
RELEASE_NOTIFY_WEBHOOK_SECRET=

# ── DigiLocker OAuth — nominee KYC (production) ──
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=

# ── Legal gate — set true only after lawyer signs clause library ──
CLAUSE_LIBRARY_SIGNED=false

# ── Optional ──
ENABLE_SMS=false