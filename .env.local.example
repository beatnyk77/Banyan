# Copy this file to .env.local and fill in values before running locally

# Claude API — for intake + will assembly
ANTHROPIC_API_KEY=

# Gate production kit issuance until lawyer signs off clause library
CLAUSE_LIBRARY_SIGNED=false

# Supabase — from your project settings or `supabase status` (local)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay — from dashboard.razorpay.com (use Test keys for development)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Resend — from resend.com/api-keys
RESEND_API_KEY=

# Banyan escrow keypair — for Shamir Share 3 encryption (Phase 1)
BANYAN_ESCROW_PUBKEY=       # NaCl box public key, hex-encoded
BANYAN_ESCROW_PRIVKEY=      # NaCl box private key — Vercel encrypted env in prod; HSM in Phase 2

# Supabase Database Webhook secret — for release-event-notify Edge Function (Phase 1)
RELEASE_NOTIFY_WEBHOOK_SECRET=

# Veto token signing key — HMAC-SHA256 (Phase 1)
VETO_TOKEN_SECRET=

# Nominee release_status_token JWT signing key — HS256 (Phase 1)
NOMINEE_TOKEN_SECRET=

# App URL — used to build absolute links (veto email, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: set "true" to enable SMS veto notification stub (Phase 2)
ENABLE_SMS=false
